#include <iostream>
#include <vector>
#include <algorithm>
#include <string>

using namespace std;

int comparisons = 0;
int swaps = 0;

int bubbleSort(vector<int>& v, int start, int end) {
    int n = end - start ;
    bool swapped; 
    for (int i = 0; i < n - 1; i++) {
        swapped = false;
        for (int j = start; j < start + n - i; j++) {
           comparisons++;
            if (v[j] > v[j + 1]) {
                swap(v[j], v[j + 1]);
                swaps++;
                swapped = true;
            }
        }
        if (!swapped) break; 
    }
    return comparisons , swaps ;
}

int selectionSort(vector<int>& v, int start, int end) {
    for (int i = start; i < end; i++) {
        int max_idx = i;
        for (int j = i + 1; j <= end; j++) {
            comparisons++;
            if (v[j] > v[max_idx]) {
                max_idx = j;
            }
        }
        if (max_idx != i) {
            swap(v[i], v[max_idx]);
            swaps++;
        }
    }
    return comparisons ,swaps;
}

int bitonicSearch(const vector<int>& v, int target) {
    for (int i = 0; i < (int)v.size(); i++) {
        if (v[i] == target) return i;
    }
    return -1;
}

void runTestCase(vector<int> v, int target) {
    cout << " Original: ";
    for (int x : v) cout << x << " ";
    
    int mid = (int)v.size() / 2;
    bubbleSort(v, 0, mid - 1);
    selectionSort(v, mid, (int)v.size() - 1);

    cout << "\n Bitonic:  ";
    for (int x : v) cout << x << " ";
    
    cout << "\n Total Comparisons: " << (comparisons)
         << "\n Total Swaps: " << (swaps) << "\n";

    int index = bitonicSearch(v, target);
    if (index != -1)
        cout << " Target " << target << " found at index: " << index << endl;
    else
        cout << " Target " << target << " not found." << endl;
    cout << "---------------------------------------\n" << endl;
}

int main() {
    runTestCase({5, 2, 9, 1, 7, 3}, 9);
    runTestCase({10, 40, 20, 50, 30}, 20);
    runTestCase({12, 5, 8, 2, 10, 15}, 5);
    runTestCase({4, 1, 8, 3}, 100 );
    runTestCase({5, 3, 5, 8, 2, 8}, 5 );
    return 0;
}
